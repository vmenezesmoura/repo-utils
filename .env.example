# ============================================================
# Arquivo de exemplo de variáveis de ambiente
# ============================================================
#
# COMO USAR:
#   1. Edite o .env e ajuste os caminhos para sua máquina.
#   2. NUNCA commite o .env (já está no .gitignore).
#   3. Sempre defina nomes de variável com UPPER CASE.
#
# ============================================================

# --- Caminhos gerais ---
# Exemplos comuns:
#   Linux:    /home/usuario/meu-repo
#   macOS:    /Users/usuario/meu-repo
#   Windows:  C:/Users/usuario/meu-repo
REPO=C:/caminho/do/meu-repo

# --- Pastas de fluxo ---
# Onde os scripts acessam os inputs e gravam arquivos e logs outputs.
# Exemplos comuns:
#   Linux:    /home/usuario/outputs/
#   macOS:    /Users/usuario/outputs/
#   Windows:  C:/Users/usuario/outputs/
INPUT=C:/caminho/do/input
OUTPUT=C:/caminho/do/output

# --- Credenciais (preencher conforme necessidade) ---
# Quando algum script precisar de tokens, senhas ou chaves de API,
# adicione aqui. Exemplo:
#
# API_TOKEN_ENVIRONLINK=
# GFS_USER=
# GFS_PASSWORD=
